<Window x:Class="WindowsTrayTasks.Views.QuickAddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quick Add"
        Width="520" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        Background="{StaticResource AppBackgroundBrush}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">
    <Border Style="{StaticResource AppCardStyle}" Margin="12">
    <StackPanel>
        <TextBlock Text="Task" Style="{StaticResource AppLabelTextStyle}"/>
        <TextBox x:Name="TitleBox" Padding="8,6" FontSize="15" Margin="0,2,0,8"/>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                <TextBlock Text="Page" Style="{StaticResource AppLabelTextStyle}"/>
                <ComboBox x:Name="PageCombo" Margin="0,2,0,0" DisplayMemberPath="Name" SelectionChanged="PageCombo_SelectionChanged"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="6,0,6,0">
                <TextBlock Text="Heading (optional)" Style="{StaticResource AppLabelTextStyle}"/>
                <ComboBox x:Name="HeadingCombo" Margin="0,2,0,0" DisplayMemberPath="Title"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Margin="6,0,0,0">
                <TextBlock Text="Reminder" Style="{StaticResource AppLabelTextStyle}"/>
                <TextBox x:Name="ReminderBox" Padding="6,4" Margin="0,2,0,4"/>
                <WrapPanel x:Name="ReminderPresets" Orientation="Horizontal"/>
            </StackPanel>
        </Grid>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <CheckBox x:Name="KeepOpenCheck" Grid.Column="0" Content="Save and add another" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="Cancel" Width="84" Margin="0,0,8,0" Click="Cancel_Click" IsCancel="True"/>
            <Button Grid.Column="2" Content="Save" Width="84" Style="{StaticResource PrimaryButtonStyle}" Click="Save_Click" IsDefault="True"/>
        </Grid>
        <TextBlock x:Name="HintText" Margin="0,8,0,0" Style="{StaticResource AppHintTextStyle}"/>
    </StackPanel>
    </Border>
</Window>
