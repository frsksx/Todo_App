<Window x:Class="WindowsTrayTasks.Views.TaskEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task"
        Width="540" Height="540"
        WindowStartupLocation="CenterOwner"
        Background="#FAFAFA"
        ShowInTaskbar="False"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Title" FontSize="11" Foreground="#666666"/>
        <TextBox x:Name="TitleBox" Grid.Row="1" Padding="6,4" Margin="0,2,0,10" FontSize="14"/>

        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                <TextBlock Text="Heading" FontSize="11" Foreground="#666666"/>
                <ComboBox x:Name="HeadingCombo" Margin="0,2,0,0" IsEditable="False" DisplayMemberPath="Title"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                <TextBlock Text="State" FontSize="11" Foreground="#666666"/>
                <ComboBox x:Name="StateCombo" Margin="0,2,0,0"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                <TextBlock Text="Start (yyyy-MM-dd HH:mm or blank)" FontSize="11" Foreground="#666666"/>
                <TextBox x:Name="StartBox" Padding="6,4" Margin="0,2,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                <TextBlock Text="Due (yyyy-MM-dd HH:mm or blank)" FontSize="11" Foreground="#666666"/>
                <TextBox x:Name="DueBox" Padding="6,4" Margin="0,2,0,0"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="4" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0" Padding="0,8,0,0" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="Reminder" FontSize="12" FontWeight="SemiBold" Foreground="#444444"/>
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Reminder time (yyyy-MM-dd HH:mm or +Nm/+Nh shorthand)" FontSize="11" Foreground="#666666"/>
                        <TextBox x:Name="ReminderBox" Padding="6,4" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Auto-snooze" FontSize="11" Foreground="#666666"/>
                        <ComboBox x:Name="AutoSnoozeCombo" Margin="0,2,0,0" Width="120"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="5" Text="Notes" FontSize="11" Foreground="#666666" Margin="0,4,0,0"/>
        <TextBox x:Name="NotesBox"
                 Grid.Row="6"
                 Margin="0,2,0,8"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 FontSize="13"/>

        <Grid Grid.Row="7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="HintText" Grid.Column="0" Foreground="#888888" FontSize="11" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="Cancel" Width="84" Margin="0,0,8,0" Click="Cancel_Click" IsCancel="True"/>
            <Button Grid.Column="2" Content="Save" Width="84" Click="Save_Click" IsDefault="True"/>
        </Grid>
    </Grid>
</Window>
