<Window x:Class="WindowsTrayTasks.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WindowsTrayTasks.Views"
        Title="Tasks"
        Width="780" Height="600"
        MinWidth="520" MinHeight="360"
        WindowStartupLocation="Manual"
        ShowInTaskbar="True"
        Background="#FAFAFA"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style TargetType="ListBoxItem" x:Key="TaskRowStyle">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E3F0FF"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="IconButtonStyle">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
        </Style>

        <DataTemplate DataType="{x:Type vm:TaskRowVm}">
            <Grid>
                <Border Visibility="{Binding IsHeading, Converter={StaticResource BoolToVisibility}}"
                        Background="#EEEEEE"
                        Padding="7,3"
                        Margin="0,4,0,2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Style="{StaticResource IconButtonStyle}"
                                Width="18"
                                Foreground="#555555"
                                Content="{Binding HeadingChevron}"
                                CommandParameter="{Binding}"
                                Click="HeadingCollapse_Click"
                                ToolTip="Collapse or expand heading"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding HeadingDisplay}"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   Foreground="#333333"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding HeadingFocusText}"
                                   FontSize="11"
                                   Foreground="#5B6F8F"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Grid Visibility="{Binding IsTask, Converter={StaticResource BoolToVisibility}}"
                      Margin="6,3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Row="0"
                            Grid.Column="0"
                            Style="{StaticResource IconButtonStyle}"
                            Width="18"
                            Height="18"
                            Margin="0,0,6,0"
                            Content="{Binding StateGlyph}"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="{Binding StateBrush}"
                            CommandParameter="{Binding}"
                            Click="StateButton_Click"
                            ToolTip="{Binding StateLabel}"/>
                    <Grid Grid.Row="0" Grid.Column="1">
                        <TextBlock Text="{Binding Title}"
                                   Visibility="{Binding TitleTextVisibility}"
                                   FontSize="12.5"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{Binding TitleBrush}"/>
                        <TextBox Text="{Binding EditTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="{Binding TitleEditorVisibility}"
                                 FontSize="12.5"
                                 Padding="2,0"
                                 BorderBrush="#8DB8E8"
                                 LostFocus="InlineTitleBox_LostFocus"
                                 KeyDown="InlineTitleBox_KeyDown"/>
                    </Grid>
                    <TextBlock Grid.Row="0"
                               Grid.Column="2"
                               Text="{Binding ReminderText}"
                               FontSize="12"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{Binding ReminderBrush}"/>
                    <TextBlock Grid.Row="0"
                               Grid.Column="3"
                               Text="{Binding DueText}"
                               FontSize="12"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#777777"/>
                    <Button Grid.Row="0"
                            Grid.Column="4"
                            Style="{StaticResource IconButtonStyle}"
                            Width="18"
                            Height="18"
                            Margin="8,0,0,0"
                            Content="{Binding ExpandGlyph}"
                            CommandParameter="{Binding}"
                            Click="ExpandButton_Click"
                            ToolTip="Expand notes and dates"/>

                    <Border Grid.Row="1"
                            Grid.Column="1"
                            Grid.ColumnSpan="4"
                            Visibility="{Binding ExpandedVisibility}"
                            Padding="0,3,0,2">
                        <StackPanel>
                            <TextBlock Text="{Binding NotesText}"
                                       FontSize="12"
                                       Foreground="#555555"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding DetailText}"
                                       FontSize="11"
                                       Foreground="#777777"
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#F8F8F8" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
            <DockPanel Margin="8,4">
                <Button DockPanel.Dock="Right"
                        Content="+"
                        Width="24"
                        Height="22"
                        Click="AddPage_Click"
                        ToolTip="Add page"/>
                <StackPanel x:Name="PageTabs" Orientation="Horizontal"/>
            </DockPanel>
        </Border>
        <Border DockPanel.Dock="Top" Background="#F0F0F0" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
            <Grid Margin="8,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Content="New"
                        Padding="8,3"
                        Margin="0,0,6,0"
                        Click="NewTask_Click"
                        ToolTip="New task (Ctrl+N)"/>
                <CheckBox x:Name="ShowEmptyHeadingsCheck"
                          Grid.Column="1"
                          Content="Show Empty Headings"
                          VerticalAlignment="Center"
                          Margin="0,0,10,0"
                          Checked="ShowEmptyHeadingsCheck_Changed"
                          Unchecked="ShowEmptyHeadingsCheck_Changed"/>
                <TextBlock Grid.Column="2"
                           Text="Find"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"
                           Foreground="#555555"/>
                <TextBox x:Name="SearchBox"
                         Grid.Column="3"
                         Padding="6,3"
                         FontSize="13"
                         BorderBrush="#CCCCCC"
                         TextChanged="SearchBox_TextChanged"
                         KeyDown="SearchBox_KeyDown"
                         ToolTip="Search (Ctrl+F or /)"/>
                <CheckBox x:Name="ShowDoneCheck"
                          Grid.Column="4"
                          Content="+ Done"
                          VerticalAlignment="Center"
                          Margin="8,0,8,0"
                          Checked="ShowDoneCheck_Changed"
                          Unchecked="ShowDoneCheck_Changed"/>
                <ComboBox x:Name="FilterCombo"
                          Grid.Column="5"
                          Width="116"
                          SelectionChanged="FilterCombo_SelectionChanged"/>
                <ComboBox x:Name="DateFilterCombo"
                          Grid.Column="6"
                          Width="116"
                          Margin="8,0,0,0"
                          SelectionChanged="DateFilterCombo_SelectionChanged"/>
            </Grid>
        </Border>
        <Border DockPanel.Dock="Bottom" Background="#F0F0F0" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusText" Margin="8,4" FontSize="12" Foreground="#555555"/>
        </Border>
        <Border DockPanel.Dock="Bottom" Background="#F8F8F8" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0">
            <WrapPanel x:Name="TagBar" Margin="6,3"/>
        </Border>
        <ListBox x:Name="TaskList"
                 BorderThickness="0"
                 Background="Transparent"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ItemContainerStyle="{StaticResource TaskRowStyle}"
                 VirtualizingStackPanel.IsVirtualizing="True"
                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                 AllowDrop="True"
                 KeyDown="TaskList_KeyDown"
                 MouseDoubleClick="TaskList_MouseDoubleClick"
                 PreviewMouseLeftButtonDown="TaskList_PreviewMouseLeftButtonDown"
                 MouseMove="TaskList_MouseMove"
                 DragOver="TaskList_DragOver"
                 Drop="TaskList_Drop"/>
    </DockPanel>
</Window>
