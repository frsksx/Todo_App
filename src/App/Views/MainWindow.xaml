<Window x:Class="WindowsTrayTasks.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WindowsTrayTasks.Views"
        Title="Tasks"
        Width="420" Height="840"
        MinWidth="360" MinHeight="520"
        WindowStartupLocation="Manual"
        ShowInTaskbar="True"
        Background="#FAFAFA"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style TargetType="ListBoxItem" x:Key="TaskRowStyle">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E3F0FF"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="IconButtonStyle">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
        </Style>

        <DataTemplate DataType="{x:Type vm:TaskRowVm}">
            <Grid>
                <Border Visibility="{Binding IsHeading, Converter={StaticResource BoolToVisibility}}"
                        Background="#EEEEEE"
                        Padding="7,3"
                        Margin="0,4,0,2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Style="{StaticResource IconButtonStyle}"
                                Width="18"
                                Foreground="#555555"
                                Content="{Binding HeadingChevron}"
                                CommandParameter="{Binding}"
                                Click="HeadingCollapse_Click"
                                ToolTip="Collapse or expand heading"/>
                        <Grid Grid.Column="1">
                            <TextBlock Text="{Binding HeadingDisplay}"
                                       Visibility="{Binding HeadingTitleVisibility}"
                                       FontWeight="SemiBold"
                                       FontStyle="{Binding HeadingFontStyle}"
                                       FontSize="12"
                                       Foreground="#333333"
                                       VerticalAlignment="Center"/>
                            <TextBox Text="{Binding EditHeadingTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Visibility="{Binding HeadingEditorVisibility}"
                                     FontSize="12"
                                     FontWeight="SemiBold"
                                     Padding="2,0"
                                     BorderBrush="#8DB8E8"
                                     LostFocus="HeadingTitleBox_LostFocus"
                                     KeyDown="HeadingTitleBox_KeyDown"/>
                        </Grid>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding HeadingFocusText}"
                                   FontSize="11"
                                   Foreground="#5B6F8F"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Grid Visibility="{Binding IsTask, Converter={StaticResource BoolToVisibility}}"
                      Margin="6,3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Row="0"
                            Grid.Column="0"
                            Style="{StaticResource IconButtonStyle}"
                            Width="18"
                            Height="18"
                            Margin="0,0,6,0"
                            Content="{Binding StateGlyph}"
                            FontSize="13"
                            FontWeight="{Binding StateGlyphFontWeight}"
                            Foreground="{Binding StateBrush}"
                            CommandParameter="{Binding}"
                            Click="StateButton_Click"
                            MouseDoubleClick="StateButton_DoubleClick"
                            ToolTip="{Binding StateLabel}">
                        <Button.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="Action" CommandParameter="{Binding}" Tag="Action" Click="StateMenuItem_Click">
                                    <MenuItem.Icon><TextBlock Text="○" Foreground="#3377CC" FontWeight="Bold" FontSize="12"/></MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Next" CommandParameter="{Binding}" Tag="Next" Click="StateMenuItem_Click">
                                    <MenuItem.Icon><TextBlock Text="○" Foreground="#C83C3C" FontWeight="Bold" FontSize="12"/></MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="On Hold" CommandParameter="{Binding}" Tag="OnHold" Click="StateMenuItem_Click">
                                    <MenuItem.Icon><TextBlock Text="Ⅱ" Foreground="#3C78DC" FontSize="12"/></MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Waiting" CommandParameter="{Binding}" Tag="Waiting" Click="StateMenuItem_Click">
                                    <MenuItem.Icon><TextBlock Text="⏱" Foreground="#8844AA" FontSize="12"/></MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Someday/Maybe" CommandParameter="{Binding}" Tag="Someday" Click="StateMenuItem_Click">
                                    <MenuItem.Icon><TextBlock Text="☁" Foreground="#AAAAAA" FontSize="12"/></MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="Done" CommandParameter="{Binding}" Tag="Done" Click="StateMenuItem_Click">
                                    <MenuItem.Icon><TextBlock Text="✓" Foreground="#4CAF50" FontSize="12"/></MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Grid Grid.Row="0" Grid.Column="1">
                        <TextBlock Text="{Binding Title}"
                                   Visibility="{Binding TitleTextVisibility}"
                                   FontSize="12.5"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   TextDecorations="{Binding TitleDecorations}"
                                   Foreground="{Binding TitleBrush}"/>
                        <TextBox Text="{Binding EditTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="{Binding TitleEditorVisibility}"
                                 FontSize="12.5"
                                 Padding="2,0"
                                 BorderBrush="#8DB8E8"
                                 LostFocus="InlineTitleBox_LostFocus"
                                 KeyDown="InlineTitleBox_KeyDown"/>
                    </Grid>
                    <TextBlock Grid.Row="0"
                               Grid.Column="2"
                               Text="{Binding ReminderText}"
                               FontSize="12"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{Binding ReminderBrush}"/>
                    <TextBlock Grid.Row="0"
                               Grid.Column="3"
                               Text="{Binding DueText}"
                               FontSize="12"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{Binding DueBrush}"
                               MouseLeftButtonDown="DueText_MouseLeftButtonDown"
                               Cursor="Hand"
                               ToolTip="Double-click to edit due date"/>
                    <Button Grid.Row="0"
                            Grid.Column="4"
                            Style="{StaticResource IconButtonStyle}"
                            Width="18"
                            Height="18"
                            Margin="8,0,0,0"
                            Content="{Binding ExpandGlyph}"
                            CommandParameter="{Binding}"
                            Click="ExpandButton_Click"
                            ToolTip="Expand notes and dates"/>

                    <Border Grid.Row="1"
                            Grid.Column="1"
                            Grid.ColumnSpan="3"
                            Visibility="{Binding ExpandedVisibility}"
                            Padding="0,3,0,2">
                        <StackPanel>
                            <vm:MarkdownTextBlock MarkdownText="{Binding NotesText}"
                                                  Visibility="{Binding NotesTextVisibility}"
                                                  FontSize="12"
                                                  Foreground="#555555"
                                                  TextWrapping="Wrap"
                                                  MouseLeftButtonDown="NotesText_MouseLeftButtonDown"
                                                  ToolTip="Click to edit notes inline"/>
                            <TextBox x:Name="NotesEditor"
                                     Text="{Binding EditNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Visibility="{Binding NotesEditorVisibility}"
                                     FontSize="12"
                                     Padding="3,2"
                                     BorderBrush="#8DB8E8"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinLines="2"
                                     MaxLines="8"
                                     KeyDown="NotesEditor_KeyDown"
                                     LostFocus="NotesEditor_LostFocus"
                                     ToolTip="Enter to save · Shift+Enter for newline · Esc to cancel"/>
                            <!-- Date chips row -->
                            <WrapPanel Margin="0,4,0,0" Orientation="Horizontal">
                                <!-- Start date chip -->
                                <Button x:Name="StartChip"
                                        Content="{Binding StartChipText}"
                                        Visibility="{Binding StartChipVisibility}"
                                        Style="{StaticResource IconButtonStyle}"
                                        FontSize="11" Foreground="#3377CC"
                                        Margin="0,0,4,0"
                                        Click="StartChip_Click"
                                        ToolTip="Click to edit start date (e.g. tomorrow 9, +2h, 2026-05-10 09:00)"/>
                                <Button Content="{Binding ClearStartText}"
                                        Visibility="{Binding ClearStartVisibility}"
                                        Style="{StaticResource IconButtonStyle}"
                                        FontSize="10" Foreground="#999999"
                                        Margin="0,0,8,0"
                                        Click="ClearStart_Click"
                                        ToolTip="Clear start date"/>
                                <DatePicker x:Name="StartDatePicker"
                                            SelectedDate="{Binding StartLocalDate, Mode=OneWay}"
                                            Visibility="{Binding StartEditorVisibility}"
                                            Width="132"
                                            FontSize="11"
                                            Margin="0,0,4,0"
                                            SelectedDateChanged="StartDatePicker_SelectedDateChanged"
                                            KeyDown="StartDatePicker_KeyDown"
                                            ToolTip="Select start date"/>
                                <!-- Due date chip -->
                                <Button x:Name="DueChip"
                                        Content="{Binding DueChipText}"
                                        Visibility="{Binding DueChipVisibility}"
                                        Style="{StaticResource IconButtonStyle}"
                                        FontSize="11" Foreground="#AA5500"
                                        Margin="0,0,4,0"
                                        Click="DueChip_Click"
                                        ToolTip="Click to edit due date"/>
                                <Button Content="{Binding ClearDueText}"
                                        Visibility="{Binding ClearDueVisibility}"
                                        Style="{StaticResource IconButtonStyle}"
                                        FontSize="10" Foreground="#999999"
                                        Margin="0,0,8,0"
                                        Click="ClearDue_Click"
                                        ToolTip="Clear due date"/>
                                <DatePicker x:Name="DueDatePicker"
                                            SelectedDate="{Binding DueLocalDate, Mode=OneWay}"
                                            Visibility="{Binding DueEditorVisibility}"
                                            Width="132"
                                            FontSize="11"
                                            Margin="0,0,4,0"
                                            SelectedDateChanged="DueDatePicker_SelectedDateChanged"
                                            KeyDown="DueDatePicker_KeyDown"
                                            ToolTip="Select due date"/>
                                <!-- Completed date (read-only) -->
                                <TextBlock Text="{Binding CompletedChipText}"
                                           Visibility="{Binding CompletedChipVisibility}"
                                           FontSize="11" Foreground="#4CAF50"
                                           Margin="0,0,8,0"/>
                                <!-- Tags -->
                                <TextBlock Text="{Binding TagsText}"
                                           Visibility="{Binding TagsVisibility}"
                                           FontSize="11" Foreground="#5577AA"
                                           Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding RecurrenceText}"
                                           Visibility="{Binding RecurrenceVisibility}"
                                           FontSize="11" Foreground="#777777"
                                           Margin="0,0,8,0"/>
                                <Button Content="{Binding LinkText}"
                                        Visibility="{Binding LinkVisibility}"
                                        Style="{StaticResource IconButtonStyle}"
                                        FontSize="11"
                                        Foreground="#3377CC"
                                        Margin="0,0,8,0"
                                        Click="TaskLink_Click"
                                        ToolTip="{Binding Link}"/>
                                <!-- Reminder detail -->
                                <TextBlock Text="{Binding ReminderDetailText}"
                                           Visibility="{Binding ReminderDetailVisibility}"
                                           FontSize="11" Foreground="{Binding ReminderBrush}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                    <StackPanel Grid.Row="1"
                                Grid.Column="4"
                                Visibility="{Binding ExpandedVisibility}"
                                VerticalAlignment="Top"
                                Margin="6,6,0,0">
                        <Button Content="→ start"
                                Style="{StaticResource IconButtonStyle}"
                                FontSize="10"
                                Foreground="#3377CC"
                                Click="StartChip_Click"
                                ToolTip="Set start date"/>
                        <Button Content="↗ due"
                                Style="{StaticResource IconButtonStyle}"
                                FontSize="10"
                                Foreground="#AA5500"
                                Margin="0,3,0,0"
                                Click="DueChip_Click"
                                ToolTip="Set due date"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <Menu x:Name="MainMenu"
              DockPanel.Dock="Top"
              Visibility="Collapsed"
              Background="#F5F5F5"
              BorderBrush="#DDDDDD"
              BorderThickness="0,0,0,1"
              LostKeyboardFocus="MainMenu_LostKeyboardFocus">
            <MenuItem Header="_File">
                <MenuItem Header="_New Task"      Click="NewTask_Click"    InputGestureText="Ctrl+N"/>
                <MenuItem Header="New _Heading"   Click="NewHeading_Click" InputGestureText="Ctrl+H"/>
                <MenuItem Header="New Page"       Click="AddPage_Click"/>
                <Separator/>
                <MenuItem Header="_Quit"          Click="Quit_Click"       InputGestureText="Alt+F4"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Delete Task"   Click="DeleteTask_Click" InputGestureText="Delete"/>
                <MenuItem Header="_Archive Task"  Click="ArchiveTask_Click"/>
                <Separator/>
                <MenuItem Header="Edit Task (details)" Click="EditTask_Click" InputGestureText="Ctrl+Enter"/>
                <Separator/>
                <MenuItem Header="Move Heading Up" Click="MoveHeadingUp_Click" InputGestureText="Ctrl+Shift+Up"/>
                <MenuItem Header="Move Heading Down" Click="MoveHeadingDown_Click" InputGestureText="Ctrl+Shift+Down"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem x:Name="MenuShowEmptyHeadings" Header="Show _Empty Headings" IsCheckable="True" Click="MenuShowEmptyHeadings_Click"/>
                <MenuItem x:Name="MenuShowDone"          Header="Show _Done"            IsCheckable="True" Click="MenuShowDone_Click"/>
                <Separator/>
                <MenuItem Header="Toggle Heading Focus"  Click="MenuToggleFocus_Click"  InputGestureText="Space"/>
                <Separator/>
                <MenuItem Header="_Forecast"     Click="MenuForecast_Click"/>
                <MenuItem Header="_Inbox"        Click="MenuInbox_Click"/>
                <MenuItem Header="_Available"    Click="MenuAvailable_Click"/>
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_Settings…"    Click="Settings_Click"/>
                <MenuItem Header="Backup Now"    Click="Backup_Click"/>
                <Separator/>
                <MenuItem Header="Pause / Resume Reminders" Click="ToggleReminders_Click"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About"        Click="About_Click"/>
            </MenuItem>
        </Menu>
        <Border DockPanel.Dock="Top" Background="#F0F0F0" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
            <Grid Margin="8,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <CheckBox x:Name="ShowEmptyHeadingsCheck"
                          Grid.Column="0"
                          Content="Show Empty Headings"
                          VerticalAlignment="Center"
                          Margin="0,0,10,0"
                          Checked="ShowEmptyHeadingsCheck_Changed"
                          Unchecked="ShowEmptyHeadingsCheck_Changed"/>
                <TextBox x:Name="SearchBox"
                         Grid.Column="1"
                         Padding="6,3"
                         FontSize="13"
                         BorderBrush="#CCCCCC"
                         TextChanged="SearchBox_TextChanged"
                         KeyDown="SearchBox_KeyDown"
                         ToolTip="Search (Ctrl+F or /)"/>
                <CheckBox x:Name="ShowDoneCheck"
                          Grid.Column="2"
                          Content="+ Done"
                          VerticalAlignment="Center"
                          Margin="8,0,8,0"
                          Checked="ShowDoneCheck_Changed"
                          Unchecked="ShowDoneCheck_Changed"/>
                <ComboBox x:Name="FilterCombo"
                          Grid.Column="3"
                          Width="140"
                          SelectionChanged="FilterCombo_SelectionChanged"
                          ToolTip="Filter and perspectives"/>
            </Grid>
        </Border>
        <Border DockPanel.Dock="Top" Background="#F8F8F8" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
            <Border.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="New Page" Click="AddPage_Click"/>
                </ContextMenu>
            </Border.ContextMenu>
            <StackPanel x:Name="PageTabs" Orientation="Horizontal" Margin="8,4"/>
        </Border>
        <Border DockPanel.Dock="Bottom" Background="#F8F8F8" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0">
            <Grid>
                <WrapPanel x:Name="TagBar" Margin="6,3">
                    <WrapPanel.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="New Tag…" Click="NewTagMenuItem_Click"/>
                        </ContextMenu>
                    </WrapPanel.ContextMenu>
                </WrapPanel>
                <Button HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="4"
                        Padding="4,2"
                        FontSize="11"
                        Content="⟳ Sync"
                        Click="SyncButton_Click"
                        ToolTip="Sync (not yet implemented)"
                        Background="Transparent"
                        BorderThickness="1"
                        BorderBrush="#CCCCCC"/>
            </Grid>
        </Border>
        <ListBox x:Name="TaskList"
                 BorderThickness="0"
                 Background="Transparent"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ItemContainerStyle="{StaticResource TaskRowStyle}"
                 VirtualizingStackPanel.IsVirtualizing="True"
                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                 AllowDrop="True"
                 KeyDown="TaskList_KeyDown"
                 MouseDoubleClick="TaskList_MouseDoubleClick"
                 PreviewMouseLeftButtonDown="TaskList_PreviewMouseLeftButtonDown"
                 PreviewMouseRightButtonDown="TaskList_PreviewMouseRightButtonDown"
                 MouseMove="TaskList_MouseMove"
                 DragOver="TaskList_DragOver"
                 DragLeave="TaskList_DragLeave"
                 Drop="TaskList_Drop">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="New Task" Click="NewTask_Click" InputGestureText="Insert"/>
                    <MenuItem Header="New Task Above" Click="NewTaskAbove_Click"/>
                    <MenuItem Header="New Task Below" Click="NewTaskBelow_Click"/>
                    <Separator/>
                    <MenuItem Header="New Heading" Click="NewHeading_Click" InputGestureText="Ctrl+H"/>
                </ContextMenu>
            </ListBox.ContextMenu>
        </ListBox>
    </DockPanel>
</Window>
