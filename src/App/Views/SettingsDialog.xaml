<Window x:Class="WindowsTrayTasks.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        Background="{StaticResource AppBackgroundBrush}">
    <Border Style="{StaticResource AppCardStyle}" Margin="12">
    <StackPanel>
        <TextBlock Text="Tabs" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AppTextBrush}" Margin="0,0,0,8"/>
        <CheckBox x:Name="ShowAgendaCheck"
                  Content="Show Agenda tab"
                  Margin="0,0,0,16"
                  IsChecked="{Binding ShowAgendaTab}"/>
        <Border BorderBrush="{StaticResource AppBorderSoftBrush}"
                BorderThickness="0,1,0,0"
                Padding="0,12,0,0"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Sync" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AppTextBrush}" Margin="0,0,0,8"/>
                <CheckBox x:Name="SyncEnabledCheck"
                          Content="Enable Supabase sync"
                          Margin="0,0,0,10"
                          IsChecked="{Binding SyncEnabled}"/>
                <TextBlock Text="Supabase URL" Style="{StaticResource AppLabelTextStyle}"/>
                <TextBox x:Name="SupabaseUrlBox"
                         Text="{Binding SupabaseUrl, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,10"
                         ToolTip="Example: https://project-ref.supabase.co"/>
                <TextBlock Text="Publishable key" Style="{StaticResource AppLabelTextStyle}"/>
                <TextBox x:Name="SupabaseKeyBox"
                         Text="{Binding SupabasePublishableKey, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,6"
                         ToolTip="Use the Supabase publishable/anon key, never a service-role key."/>
                <TextBlock Text="Remote sync still requires a matching Supabase schema and sign-in/session wiring."
                           Style="{StaticResource AppHintTextStyle}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="80" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="OK" Width="80" Style="{StaticResource PrimaryButtonStyle}" IsDefault="True" Click="OK_Click"/>
        </StackPanel>
    </StackPanel>
    </Border>
</Window>
