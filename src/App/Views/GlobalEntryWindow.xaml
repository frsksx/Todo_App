<Window x:Class="WindowsTrayTasks.Views.GlobalEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quick Entry"
        Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        Background="{StaticResource AppBackgroundBrush}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">
    <Border Style="{StaticResource AppCardStyle}" Margin="12">
    <StackPanel>
        <TextBlock Text="Task" Style="{StaticResource AppLabelTextStyle}"/>
        <TextBox x:Name="TitleBox" Padding="8,6" FontSize="14" Margin="0,2,0,10"/>

        <TextBlock Text="Notes (optional)" Style="{StaticResource AppLabelTextStyle}"/>
        <TextBox x:Name="NotesBox"
                 Padding="6,5" FontSize="12"
                 Margin="0,2,0,10"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 MinLines="2" MaxLines="5"/>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Start (optional)" Style="{StaticResource AppLabelTextStyle}"/>
                <TextBox x:Name="StartBox"
                         Padding="6,4" FontSize="12" Margin="0,2,0,0"
                         ToolTip="e.g. tomorrow 9, +2h, 2026-05-10 09:00"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Due (optional)" Style="{StaticResource AppLabelTextStyle}"/>
                <TextBox x:Name="DueBox"
                         Padding="6,4" FontSize="12" Margin="0,2,0,0"
                         ToolTip="e.g. tomorrow, +1d, 2026-05-10"/>
            </StackPanel>
        </Grid>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="HintText"
                       Grid.Column="0"
                       Style="{StaticResource AppHintTextStyle}"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="Cancel" Width="84" Margin="0,0,8,0"
                    Click="Cancel_Click" IsCancel="True"/>
            <Button Grid.Column="2" Content="Save" Width="84"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="Save_Click" IsDefault="True"/>
        </Grid>
    </StackPanel>
    </Border>
</Window>
